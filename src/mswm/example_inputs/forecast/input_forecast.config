# ------------------------------------------------
# Main Input Configuration File
#
# This file is used to create the input config files and realization file used to run Ngen.
# It contains five sections:
#    1. General
#    2. Regionalization
#    3. Calibration
#    4. Forcing
#    5. DataFile
# Variables in the sections for unused run types (i.e. calibration section for a regionalization run) are not loaded
# ------------------------------------------------

[Forcing]
# Forcing provider (csv or bmi)
forcing_provider = bmi

# Directory for csv input forcing data (required for csv provider, not required for bmi provider)
forcing_dir = 

# Forcing engine template file directory
forcing_template_dir = ~/ngwpc/ngen-forcing/NextGen_Forcings_Engine_BMI/BMI_NextGen_Configs/config_templates/

# Forcing engine root directory (used to specify root location of forecast files)
# Ngencerf: /ngencerf/data/forecast_work
# Local base modules (not via ngencerf): /ngen-app/data
root_dir = /ngen-app/data

# Forcing engine configurations
forcing_configuration = standard_ana

# Cycle time for start of forecast (and/or cold start end time when used)
cycle_datetime = 2025-09-17 10:00:00

# Start of cold start period
cold_start_datetime = 2025-09-09 14:00:00

# Global domain. Currently only affects historical NWM forcing.
# Default: CONUS. Choices: CONUS, Alaska, Hawaii, Puerto_Rico
global_domain = 

[NWMOutput]
nwm_output_variables = True

[DataFile]
# Directory or file for constant/additional module parameters (currently applicable to noah, lasam, ueb, sac-sma, and snow-17)
# these can be found in the nwm-msw-mgr source repo under nwm-msw-mgr/module_parameter_files
noah_parameter_dir = ~/ngwpc/nwm-msw-mgr/module_parameter_files/noah-owp-modular
ueb_parameter_dir = ~/ngwpc/nwm-msw-mgr/module_parameter_files/ueb
lasam_parameter_dir = ~/ngwpc/nwm-msw-mgr/module_parameter_files/lasam
lstm_parameter_dir = ~/ngwpc/nwm-msw-mgr/module_parameter_files/lstm
sac_sma_parameter_dir = ~/s3/ngwpc-hydrofabric
snow_17_parameter_dir = ~/s3/ngwpc-hydrofabric

# Library files for modules (can be left blank if module is not selected)
sloth_lib = ~/ngwpc/ngen/extern/sloth/cmake_build/libslothmodel.so
cfe_lib = ~/ngwpc/ngen/extern/cfe/cmake_build/libcfebmi.so
lasam_lib = ~/ngwpc/ngen/extern/LASAM/cmake_build/liblasambmi.so
noah_owp_modular_lib = ~/ngwpc/ngen/extern/noah-owp-modular/cmake_build/libsurfacebmi.so
pet_lib = ~/ngwpc/ngen/extern/evapotranspiration/evapotranspiration/cmake_build/libpetbmi.so
sac_sma_lib = ~/ngwpc/ngen/extern/sac-sma/cmake_build/libsacbmi.so
sft_lib = ~/ngwpc/ngen/extern/SoilFreezeThaw/cmake_build/libsftbmi.so
smp_lib = ~/ngwpc/ngen/extern/SoilMoistureProfiles/cmake_build/libsmpbmi.so
snow_17_lib = ~/ngwpc/ngen/extern/snow17/cmake_build/libsnow17bmi.so
topmodel_lib = ~/ngwpc/ngen/extern/topmodel/cmake_build/libtopmodelbmi.so
ueb_lib = ~/ngwpc/ngen/extern/ueb-bmi/cmake_build/src/libbmiuebcxx.so
